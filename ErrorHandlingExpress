3)⚙️ Try–Catch Error Handling in Express.js (MAIN)

🧠 Definition (Easy Words):
The try...catch block is used to catch errors in your code so your app doesn’t crash.
Code inside try runs normally.
If an error happens, it jumps to the catch block.
You can then send a friendly message to the user instead of breaking the app.
It’s like a safety net — if something fails, you handle it gracefully.

const express = require('express');
const app = express();

// Middleware to parse JSON
app.use(express.json());

// 🧩 1️⃣ Normal route with try–catch
app.get('/user', (req, res) => {
  try {
    let users = null;
    if (!users) throw new Error("No users found");
    res.send(users);
  } catch (err) {
    res.status(500).send({ message: err.message });
  }
});

// ⚙️ 2️⃣ Async route with try–catch (async/await)
app.get('/data', async (req, res) => {
  try {
    // Fake async example
    const result = await new Promise((resolve, reject) => {
      setTimeout(() => reject(new Error("Database connection failed")), 500);
    });

    res.send(result);
  } catch (error) {
    res.status(500).json({ message: "Failed to fetch data", error: error.message });
  }
});

// 🔁 3️⃣ Route with try–catch + next() for global error handling
app.get('/product', async (req, res, next) => {
  try {
    const product = null; // pretend DB result
    if (!product) throw new Error("Product not found");
    res.json(product);
  } catch (err) {
    next(err); // send to global error handler
  }
});

// 🧱 Global Error Handler (must be last)
app.use((err, req, res, next) => {
  res.status(500).json({ message: "Something went wrong!", error: err.message });
});

// Start server
app.listen(3000, () => console.log('Server running on port 3000'));


-------------------------------------------------------------------------------------------------------------------
You only need these 3 patterns:

Try–Catch in normal routes
Try–Catch in async/await routes
Try–Catch + next() for global error handling
These are enough for 90% of real Express apps.
